# HVO.Enterprise Environment Variables Template
# Copy this file to .env.development for local development (git-ignored)
#
# Non-sensitive configuration values with defaults
# Override in .env.development file or environment for custom values

# ASP.NET Core Environment
ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development

# =====================================================
# PostgreSQL Configuration (for sample apps / integration tests)
# =====================================================
# HVO_POSTGRES_HOST=postgres
# HVO_POSTGRES_HOST_LOCAL=127.0.0.1
# HVO_POSTGRES_PORT=5432
# HVO_POSTGRES_DATABASE=hvo
# HVO_POSTGRES_USERNAME=postgres
# HVO_POSTGRES_PASSWORD=postgres

# =====================================================
# Redis Configuration (for sample apps / integration tests)
# =====================================================
# HVO_REDIS_HOST=redis
# HVO_REDIS_HOST_LOCAL=127.0.0.1
# HVO_REDIS_PORT=6379

# =====================================================
# Logging Configuration (non-sensitive)
# =====================================================
LOGGING_LOGLEVEL_DEFAULT=Information
LOGGING_LOGLEVEL_MICROSOFT_ASPNETCORE=Warning

# =====================================================
# NuGet Publishing (CI/CD only)
# =====================================================
# NUGET_API_KEY=<your-nuget-api-key>
# NUGET_SOURCE=https://api.nuget.org/v3/index.json

# =====================================================
# SECRETS - DO NOT SET IN THIS FILE
# =====================================================
# Set these via:
# - User Secrets (dotnet user-secrets set "KeyName" "value")
# - Environment variables in production
# - GitHub Secrets for CI/CD
